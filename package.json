{
  "name": "pokemon-web",
  "version": "1.0.0",
  "description": "A browser-based Pokemon-style RPG built with Phaser 3 + TypeScript + Vite",
  "type": "module",
  "scripts": {
    "dev": "vite --config frontend/vite.config.ts",
    "generate-icons": "node frontend/scripts/generate-icons.js",
    "generate-atlas": "node frontend/scripts/generate-atlas.js",
    "generate-pixel-font": "node frontend/scripts/generate-pixel-font.js",
    "build": "node frontend/scripts/generate-icons.js && node frontend/scripts/generate-atlas.js && node frontend/scripts/generate-pixel-font.js && tsc --project frontend/tsconfig.json --noEmit && vite build --config frontend/vite.config.ts",
    "preview": "vite preview --config frontend/vite.config.ts",
    "test": "vitest run --config tests/vitest.config.ts",
    "test:watch": "vitest --config tests/vitest.config.ts",
    "test:unit": "vitest run --config tests/vitest.config.ts --include 'unit/**'",
    "test:integration": "vitest run --config tests/vitest.config.ts --include 'integration/**'",
    "test:e2e": "npx playwright test --config tests/e2e/playwright.config.ts",
    "test:e2e:smoke": "npx playwright test --config tests/e2e/playwright.config.ts tests/e2e/smoke.spec.ts",
    "test:visual": "npx playwright test --config tests/e2e/playwright.config.ts tests/e2e/visual.spec.ts",
    "test:visual:update": "npx playwright test --config tests/e2e/playwright.config.ts tests/e2e/visual.spec.ts --update-snapshots",
    "test:perf": "npx playwright test --config tests/e2e/playwright.config.ts tests/e2e/performance.spec.ts",
    "test:fuzz": "npx playwright test --config tests/e2e/playwright.config.ts tests/fuzz/",
    "test:coverage": "vitest run --config tests/vitest.config.ts --coverage",
    "test:all": "npm run test && npm run test:e2e",
    "map:validate": "npx tsx temp/scripts/map-gen/cli.ts validate",
    "map:preview": "npx tsx temp/scripts/map-gen/cli.ts preview",
    "map:preview-all": "npx tsx temp/scripts/map-gen/cli.ts preview --all",
    "map:gen": "npx tsx temp/scripts/map-gen/cli.ts",
    "map:compose": "npx tsx temp/scripts/map-gen/cli.ts compose",
    "map:region": "npx tsx temp/scripts/map-gen/region/region-map.ts",
    "deploy": "npm run build && npx gh-pages -d dist"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@vitest/coverage-v8": "^4.1.4",
    "phaser": "^3.90.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
